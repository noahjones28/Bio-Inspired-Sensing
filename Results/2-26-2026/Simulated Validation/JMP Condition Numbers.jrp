Local Here(
	(table1 = New Table( "JMP Condition Numbers",
		Add Rows( 240 ),
		New Table Variable( "Design", "Fast Flexible Filling Design" ),
		New Script(
			"Source",
			Data Table( "Fast Flexible Filling Design" ) <<
			Sort(
				By( :delta ),
				Order( Descending ),
				Output Table( "Sort of Fast Flexible Filling Design by delta" )
			)
		),
		New Script(
			"Model",
			Gaussian Process(
				Y( :"Force Error (N)"n, :Position Error, :Angle Error ),
				X( :F1, :s1, :theta1, :F2, :delta, :theta2, :tau1, :tau2, :tau3 )
			)
		),
		New Script( "Disallowed Combinations", s1 - delta < 0.02 ),
		New Script(
			"DOE Dialog",
			DOE(
				Space Filling Design,
				{Add Response( Minimize, "Force Error", ., ., . ),
				Add Response( Minimize, "Position Error", ., ., . ),
				Add Response( Minimize, "Angle Error", ., ., . ),
				Add Factor( Continuous, 0.3, 1.5, "F1", 0 ),
				Add Factor(
					Discrete Numeric,
					{0.02, 0.04, 0.06, 0.08, 0.1, 0.12, 0.14, 0.16, 0.18, 0.2},
					"s1",
					0
				), Add Factor(
					Discrete Numeric,
					{0, 0.7854, 1.5708, 2.3562, 3.1416, 3.927, 4.7124, 5.4978},
					"theta1",
					0
				), Add Factor( Continuous, 0.3, 1.5, "F2", 0 ),
				Add Factor(
					Discrete Numeric,
					{0.04, 0.06, 0.08, 0.1, 0.12, 0.14, 0.16, 0.18},
					"delta",
					0
				), Add Factor(
					Discrete Numeric,
					{0, 0.7854, 1.5708, 2.3562, 3.1416, 3.927, 4.7124, 5.4978},
					"theta2",
					0
				), Add Factor( Continuous, 0, 5, "tau1", 0 ),
				Add Factor( Continuous, 0, 5, "tau2", 0 ),
				Add Factor( Continuous, 0, 5, "tau3", 0 ),
				Set Random Seed( 913398727 ),
				Disallowed Combinations( s1 - delta < 0.02 ),
				FFF Optimality Criterion( MaxPro ),
				Space Filling Design Type( Fast Flexible Filling, 60 ),
				Simulate Responses( 0 ), Set Run Order( Randomize ), Make Table}
			)
		),
